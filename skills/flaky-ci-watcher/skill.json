{
  "name": "flaky-ci-watcher",
  "version": "1.0.0",
  "description": "Watch your approved open PRs, auto re-run flaky CI failures, and alert in the terminal when a failure looks real or stays flaky",
  "author": "Philipp Hofmann",
  "capabilities": [
    "github-query",
    "ci-monitoring",
    "ci-rerun",
    "failure-analysis"
  ],
  "requirements": {
    "tools": [
      "gh (GitHub CLI)",
      "jq"
    ],
    "permissions": [
      "Read access to your repositories",
      "Actions: re-run workflow jobs (gh run rerun)"
    ]
  },
  "safety": {
    "no_approvals": true,
    "no_merges": true,
    "no_auto_merge": true,
    "no_comments": true,
    "no_commits": true,
    "no_code_changes": true,
    "only_write_action": "gh run rerun --failed (flaky-looking failures only)"
  },
  "configuration": {
    "scope": "my approved open PRs across all repositories",
    "rerun_cap": 2,
    "notify_channel": "terminal",
    "state_file": "${TMPDIR:-/tmp}/flaky-ci-watcher-state.json",
    "recommended_driver": "/loop 5m /flaky-ci-watcher"
  }
}
